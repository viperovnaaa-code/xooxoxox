--// Global Configuration
getgenv().SilentAim       = false
getgenv().ShowFOV         = false
getgenv().TargetKnocked   = false
getgenv().FOVRadius       = 100
getgenv().SilentAimPart   = "Head"
getgenv().NearestPart     = false
getgenv().SilentPrediction = false 
getgenv().PredictionAmount = 0.165   
getgenv().SpreadValue     = 15

local Whitelist = {}

--// Gun System Integration
local success, GunHandler = pcall(require, ReplicatedStorage:WaitForChild("Modules"):WaitForChild("GunHandler"))

--// Utility Functions
local function GetTargetPart(player)
    local character = player.Character
    if not character then return nil end

    if getgenv().NearestPart then
        local bestPart = nil
        local shortestDist = math.huge
        local parts = {"Head", "UpperTorso", "LowerTorso", "HumanoidRootPart"}

        for _, partName in ipairs(parts) do
            local part = character:FindFirstChild(partName)
            if part then
                local screenPos, onScreen = Camera:WorldToViewportPoint(part.Position)
                if onScreen then
                    local mouseDist = (UserInputService:GetMouseLocation() - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                    if mouseDist < shortestDist then
                        shortestDist = mouseDist
                        bestPart = part
                    end
                end
            end
        end
        return bestPart
    end

    return character:FindFirstChild(getgenv().SilentAimPart) or character:FindFirstChild("HumanoidRootPart")
end

local function GetSniperTarget()
    local target, shortestDistance = nil, getgenv().FOVRadius

    for _, player in ipairs(Players:GetPlayers()) do
        if player ~= LocalPlayer and player.Character and not Whitelist[player.UserId] then
            local hitPart = GetTargetPart(player)
            
            if hitPart then
                local humanoid = player.Character:FindFirstChild("Humanoid")
                local bodyEffects = player.Character:FindFirstChild("BodyEffects")
                local isKO = bodyEffects and bodyEffects:FindFirstChild("K.O") and bodyEffects["K.O"].Value
                
                if humanoid and humanoid.Health > 0 and (getgenv().TargetKnocked or not isKO) then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(hitPart.Position)
                    if onScreen then
                        local dist = (UserInputService:GetMouseLocation() - Vector2.new(screenPos.X, screenPos.Y)).Magnitude
                        if dist < shortestDistance then 
                            shortestDistance = dist
                            target = hitPart
                        end
                    end
                end
            end
        end
    end
    return target
end

--// Silent Aim Hook
if success then
    local oldShoot; oldShoot = hookfunction(rawget(GunHandler, "shoot"), function(args)
        if getgenv().SilentAim and rawget(args, "Shooter") == LocalPlayer.Character then
            local target = GetSniperTarget()
            
            if target then
                local hitPos = target.Position
                
                -- Handle Prediction
                if getgenv().SilentPrediction then
                    hitPos = hitPos + (target.Velocity * getgenv().PredictionAmount)
                end
                
                -- Handle Spread
                local spreadScale = (getgenv().SpreadValue / 100) * 5
                local offset = Vector3.new(
                    math.random(-100, 100) / 100 * spreadScale,
                    math.random(-100, 100) / 100 * spreadScale,
                    math.random(-100, 100) / 100 * spreadScale
                )
                
                local finalPos = hitPos + offset
                local muzzlePos = args["Muzzle"] and args["Muzzle"].WorldPosition or Camera.CFrame.Position
                
                args["AimPosition"] = finalPos
                args["Direction"] = (finalPos - muzzlePos).Unit
                args["Hit"] = target
                
                return oldShoot(args)
            end
        end
        return oldShoot(args)
    end)
end

